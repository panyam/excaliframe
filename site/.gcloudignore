# This file specifies files that are *not* uploaded to Google Cloud.
# Only Go sources, templates, and built static assets are needed at runtime.

.gcloudignore
.git
.gitignore

# Frontend source and build tooling (not needed at runtime)
node_modules/
pages/
package.json
package-lock.json
pnpm-lock.yaml
tsconfig.json
webpack.config.js
rspack.config.js

# Python / E2E artifacts
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
test-results/
playwright-report/

# Local dev artifacts
locallinks/
bin/
Makefile
SUMMARY.md
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Source maps (not needed in production)
static/playground/**/*.map
