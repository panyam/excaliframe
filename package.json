{
  "name": "excaliframe",
  "version": "0.0.10",
  "description": "Atlassian Forge app for Excalidraw drawings in Confluence",
  "scripts": {
    "update-version": "node scripts/update-version.js",
    "build": "npm run update-version && webpack --mode production",
    "build:rspack": "npm run update-version && rspack build --mode production",
    "dev": "webpack --mode development --watch",
    "dev:rspack": "rspack build --mode development --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "forge:deploy": "npm run build && forge deploy",
    "forge:install": "forge install",
    "forge:tunnel": "npm run build && forge tunnel"
  },
  "keywords": [
    "confluence",
    "atlassian",
    "forge",
    "excalidraw",
    "drawing",
    "whiteboard"
  ],
  "author": "Sriram Panyam",
  "license": "MIT",
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@forge/api": "^4.0.0",
    "@forge/bridge": "^4.0.0",
    "@forge/resolver": "^1.6.0",
    "@panyam/massrelay": "^0.0.10",
    "@panyam/servicekit-client": "^0.0.6",
    "mermaid": "^11.12.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@forge/cli": "^10.0.0",
    "@rspack/cli": "^1.3.0",
    "@rspack/core": "^1.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "eslint": "^8.57.0",
    "html-webpack-plugin": "^5.5.3",
    "jsdom": "^28.1.0",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "vitest": "^4.0.18",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  }
}
